# Environment variables for development
DEBUG=True
SECRET_KEY=django-insecure-development-key-change-in-production

# Database
DB_NAME=chifash_prod
DB_USER=postgres
DB_PASSWORD=postgres_secure_pwd
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_PASSWORD=redis_secure_pwd

# Django Settings
DJANGO_SETTINGS_MODULE=config.settings

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,chifash.local

# JWT Settings
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Email Configuration (SendGrid/AWS SES)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.xxxxxxxxxxxxx

# Cloudinary (Production)
CLOUDINARY_CLOUD_NAME=chifash
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx

# Frontend
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cors
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# SSL (Production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
